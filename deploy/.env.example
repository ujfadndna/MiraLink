# Deployment environment template
# Copy to a private local file before use. Do not commit secrets or host-specific values.

APP_HOST=<public-demo-host>
APP_PORT=8443

BACKEND_URL=http://127.0.0.1:8100
SIGNALLING_URL=http://127.0.0.1:8080

TURN_PUBLIC_IP=<turn-public-ip>
TURN_URLS=turn:<turn-public-ip>:3478?transport=udp
TURN_USERNAME=<turn-username>
TURN_CREDENTIAL=<turn-credential>

SEETA_SSH_HOST=<cloud-ssh-host>
SEETA_SSH_PORT=<cloud-ssh-port>
SEETA_SSH_USER=<cloud-user>
# Set SEETA_SSH_PASSWORD in the current shell/session only.
