# MiraLink backend environment template
# Copy to backend/.env for local development. Never commit backend/.env.

# Server
SERVER_PORT=8100
WORKSPACE_DIR=./workspace
WARMUP_ON_START=true

# Agent / LLM
# This demo template points at a real-compatible agent backend.
# Switch to AGENT_BACKEND=mock for offline smoke tests.
AGENT_BACKEND=langgraph
AGENT_LLM_MODEL=deepseek-chat
AGENT_LLM_TEMPERATURE=0.7
ANTHROPIC_API_KEY=<your-anthropic-or-compatible-key>
ANTHROPIC_BASE_URL=<optional-compatible-base-url>

# OpenAI-compatible optional services
OPENAI_API_KEY=<your-openai-key>
OPENAI_BASE_URL=<optional-openai-compatible-base-url>

# Web search, optional
WEB_SEARCH_BACKEND=mock
WEB_SEARCH_MODEL=<web-search-model>
WEB_SEARCH_CONTEXT_SIZE=low
WEB_SEARCH_EXTERNAL_WEB_ACCESS=true
WEB_SEARCH_TIMEOUT_SEC=12

# TTS
# This demo template points at a real TTS adapter.
# Switch to TTS_BACKEND=mock for offline smoke tests.
TTS_BACKEND=indextts
TTS_SAMPLE_RATE=24000
INDEXTTS_API_URL=http://127.0.0.1:9001
CALL_BARGE_IN_ENABLED=false

# ASR
# mock is for smoke tests only. Use faster_whisper or cloud_whisper for real voice acceptance.
ASR_BACKEND=mock
ASR_MODEL=<local-or-cloud-asr-model>
ASR_API_URL=http://127.0.0.1:9002

# Optional cloud GPU SSH values for local tools.
# Set SEETA_SSH_PASSWORD only in the current shell/session, never in this file.
SEETA_SSH_HOST=<cloud-ssh-host>
SEETA_SSH_PORT=<cloud-ssh-port>
SEETA_SSH_USER=<cloud-user>
